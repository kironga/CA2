
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=replace-with-a-secure-secret
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_SESSION_TIMEOUT_SECONDS=300
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=no-reply@ca2.go.ke
DJANGO_EMAIL_HOST=smtp.gmail.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=true
DJANGO_EMAIL_USE_SSL=false
DJANGO_EMAIL_TIMEOUT=20
DJANGO_EMAIL_HOST_USER=your-real-email@gmail.com
DJANGO_EMAIL_HOST_PASSWORD=your-app-password
CA2_GOVERNMENT_REG_EMAIL=verification@ca2.go.ke
